<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center_vertical"
    android:padding="16dp" android:background="#F4F1FF">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Copilot Remote" android:textStyle="bold" android:textSize="18sp" android:textColor="#312E81" />
    <Button android:id="@+id/widget_open" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:text="打开对话" />
</LinearLayout>
